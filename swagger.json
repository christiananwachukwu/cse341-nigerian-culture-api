{
  "openapi": "3.0.0",
  "info": {
    "title": "Nigerian Culture API",
    "version": "1.0.0",
    "description": "A RESTful API celebrating Nigerian cultural heritage — Dishes, Festivals, Traditional Rulers & Folklore"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    },
    {
      "url": "https://cse341-nigerian-culture-api.onrender.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/dishes": {
      "get": {
        "summary": "Get all dishes",
        "responses": {
          "200": { "description": "List all Nigerian dishes" }
        }
      },
      "post": {
        "summary": "Create a new dish",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "region", "tribe", "ingredients", "preparation", "occasion", "servingStyle"],
                "properties": {
                  "name": { "type": "string" },
                  "region": { "type": "string" },
                  "tribe": { "type": "string" },
                  "ingredients": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "preparation": { "type": "string" },
                  "occasion": { "type": "string" },
                  "servingStyle": { "type": "string" },
                  "imageUrl": { "type": "string" },
                  "nutritionalNotes": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Dish created successfully" },
          "400": { "description": "Missing required fields" }
        }
      }
    },

    "/dishes/{id}": {
      "get": {
        "summary": "Get a dish by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Dish found" },
          "404": { "description": "Dish not found" }
        }
      },
      "put": {
        "summary": "Update a dish by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": { "description": "Dish updated" },
          "404": { "description": "Dish not found" }
        }
      },
      "delete": {
        "summary": "Delete a dish by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Dish deleted successfully" },
          "404": { "description": "Dish not found" }
        }
      }
    },

    "/festivals": {
      "get": {
        "summary": "Get all festivals",
        "responses": {
          "200": {
            "description": "List of festivals"
          }
        }
      },
      "post": {
        "summary": "Create a festival",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "region": { "type": "string" },
                  "tribe": { "type": "string" },
                  "dateSeason": { "type": "string" },
                  "duration": { "type": "string" },
                  "traditions": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "significance": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Festival created"
          }
        }
      }
    },

    "/festivals/{id}": {
      "get": {
        "summary": "Get a festival by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Festival found"
          }
        }
      },
      "put": {
        "summary": "Update a festival",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Festival updated"
          }
        }
      },
      "delete": {
        "summary": "Delete a festival",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Festival deleted"
          }
        }
      }
    },

    "/rulers": {
      "get": {
        "summary": "Get all traditional rulers and kingdoms",
        "responses": {
          "200": { "description": "List of all Nigerian traditional rulers and kingdoms" }
        }
      },
      "post": {
        "summary": "Create a new ruler/kingdom entry",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "kingdom", "tribe", "currentHolder", "historicalSignificance", "coronationTraditions", "region", "state", "foundedYear"],
                "properties": {
                  "title": { "type": "string" },
                  "kingdom": { "type": "string" },
                  "tribe": { "type": "string" },
                  "currentHolder": { "type": "string" },
                  "historicalSignificance": { "type": "string" },
                  "coronationTraditions": { "type": "string" },
                  "region": { "type": "string" },
                  "state": { "type": "string" },
                  "foundedYear": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Ruler created successfully" },
          "400": { "description": "Missing required fields" }
        }
      }
    },

    "/rulers/{id}": {
      "get": {
        "summary": "Get a ruler by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Ruler found" },
          "404": { "description": "Ruler not found" }
        }
      },
      "put": {
        "summary": "Update a ruler by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {"type": "object"}
            }
          }
        },
        "responses": {
          "200": { "description": "Ruler updated" },
          "404": { "description": "Ruler not found" }
        }
      },
      "delete": {
        "summary": "Delete a ruler by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Ruler deleted successfully" },
          "404": { "description": "Ruler not found" }
        }
      }
    },

    "/folklore": {
      "get": {
        "summary": "Get all folklore stories",
        "responses": {
          "200": { "description": "List of all Nigerian folklore stories" }
        }
      },
      "post": {
        "summary": "Create a new folklore story",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "tribe", "characters", "storySummary", "moralLesson", "storyType", "languageOfOrigin", "ageGroup", "region"],
                "properties": {
                  "title": { "type": "string"},
                  "tribe": { "type": "string"},
                  "characters": { 
                    "type": "array"},
                    "items": { "type": "string"}
                },
                "storySummary": { "type": "string"},
                "moralLesson": { "type": "string"},
                "storyType": {
                  "type": "string",
                  "enum": ["folklore", "legend", "myth", "fable", "epic"]
                },
                "languageOfOrigin": { "type": "string"},
                "ageGroup": {
                  "type": "string",
                  "enum": ["children", "adults", "all ages" ]
                },
                "region": { "type": "string"}
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Folklore created successfully" },
          "400": { "description": "Missing required fields"}
        }
      }
    },

    "/folklore/{id}": {
      "get": {
        "summary": "Get a folklore story by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Folklore found" },
          "404": { "description": "Folklore not found" }
        }
      },
      "put": {
        "summary": "Update a folklore story by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "type": "object"}
            }
          }
        },
        "responses": {
          "200": { "description": "Folklore updated" },
          "404": { "description": "Folklore not found" }
        }
      },
      "delete": {
        "summary": "Delete a folklore story by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Folklore deleted successfully" },
          "404": { "description": "Folklore not found" }
        }
      }
    }
  }
}